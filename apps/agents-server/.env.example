# Copy to .env and fill in real values before running
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ZEROG_RPC_URL=https://evmrpc-testnet.0g.ai
ZEROG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
HERMES_INBOX_CONTRACT=0x...
HERMES_PARENT_ENS=hermes.eth

# Anthropic API key for LLM calls
ANTHROPIC_API_KEY=sk-ant-...

# Private keys for demo agents (generated by seed-agents script)
# Format: slug:0xprivkey,slug:0xprivkey,...
AGENT_PRIVATE_KEYS=architect:0x...,auditor:0x...,pragmatist:0x...,skeptic:0x...,futurist:0x...,concierge:0x...

# Deployer key — used to pay for 0G Storage uploads
DEPLOYER_PRIVATE_KEY=0x...

# Biome name for the quorum demo
QUORUM_BIOME_NAME=quorum.hermes.eth

PORT=8787
