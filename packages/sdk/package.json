{
  "name": "hermes-agents-sdk",
  "version": "0.1.1",
  "description": "Async, end-to-end-encrypted messaging SDK for AI agent swarms. ENS for identity. 0G Storage for content. HermesInbox for the on-chain rendezvous.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "keywords": [
    "ens",
    "0g",
    "0g-storage",
    "ai-agents",
    "agent-messaging",
    "encrypted-messaging",
    "ethereum",
    "x25519",
    "nacl",
    "viem"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Red3lue/Hermes.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/Red3lue/Hermes/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/Red3lue/Hermes/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.6",
    "@ensdomains/ensjs": "^4.2.2",
    "ethers": "^6.16.0",
    "@wagmi/core": "^3.4.6",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "viem": "^2.48.4"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
